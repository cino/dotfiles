# Python
alias python='python3'
alias pip='pip3'

# Git
alias git='hub'
alias sshow="git stash show stash^{/$*} -p"
alias sapply="git stash apply stash^{/$*}"
alias ssave="git stash save "${1}""
alias gs="hub sync"

# Dotfiles
alias dotfiles='git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'

# Docker
alias dex='docker-compose exec app'

# PHP
alias test="php -n ./vendor/bin/phpunit --colors=always"

# Laravel
alias a="php artisan"
alias am="php artisan migrate"
alias amr="php artisan migrate:rollback"
alias logall="tail -f **/*.log"
alias lca="php artisan route:clear && php artisan cache:clear && php artisan view:clear && php artisan config:clear"

alias phpunit="./vendor/bin/phpunit"
alias gfp="git fetch && git pull"
alias barbecuuee="git reset --hard && git clean -df && echo -e '\033[1m\nwho wantz to be a burgerrr 🔥'"
alias mysqltop="watch -n 1 --differences \"mysql -uroot -e 'SHOW FULL PROCESSLIST;'\""
alias npmwatch="rm -rf node_modules && rm package-lock.json && npm install && npm run watch"
alias please='sudo $(history -p !!)'

# Quick locations
alias dev='cd ~/Dev'
