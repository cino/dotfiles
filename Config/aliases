# Various
alias timestamp="date '+%s'"

# Git
alias git='hub'
alias gs="hub sync"

# Dotfiles
alias dotfiles='git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'
alias rmail='sudo rm -rf /var/mail/$USER'

# Terraform
alias tf='terraform'

# Docker
alias dex='docker-compose exec'
alias dc='docker-compose'

# PHP
